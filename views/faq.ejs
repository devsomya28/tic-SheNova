<script>
  // ── Toggle accordion ──
  function toggleFAQ(btn) {
    const item = btn.closest('.faq-item');
    const answer = item.querySelector('.faq-answer');
    const isOpen = item.classList.contains('faq-open');

    // Close all
    document.querySelectorAll('.faq-item.faq-open').forEach(i => {
      i.classList.remove('faq-open');
      i.querySelector('.faq-answer').style.maxHeight = '0';
    });

    // Open clicked (if it wasn't open)
    if (!isOpen) {
      item.classList.add('faq-open');
      answer.style.maxHeight = answer.scrollHeight + 'px';
    }
  }

  // ── Category filter ──
  function filterFAQ(category, btn) {
    document.querySelectorAll('.faq-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Clear search
    document.getElementById('faqSearch').value = '';

    const items = document.querySelectorAll('.faq-item');
    const labels = document.querySelectorAll('.faq-section-label');

    items.forEach(item => {
      if (category === 'all' || item.dataset.category === category) {
        item.classList.remove('faq-hidden');
      } else {
        item.classList.add('faq-hidden');
        item.classList.remove('faq-open');
        item.querySelector('.faq-answer').style.maxHeight = '0';
      }
    });

    labels.forEach(label => {
      label.style.display = (category === 'all' || label.dataset.section === category) ? '' : 'none';
    });

    document.getElementById('noResults').classList.remove('visible');
  }

  // ── Search ──
  function searchFAQ(query) {
    const q = query.toLowerCase().trim();
    const items = document.querySelectorAll('.faq-item');
    const labels = document.querySelectorAll('.faq-section-label');

    // Reset filter buttons
    document.querySelectorAll('.faq-filter-btn').forEach(b => b.classList.remove('active'));
    document.querySelector('.faq-filter-btn').classList.add('active');

    let visibleCount = 0;

    items.forEach(item => {
      const keywords = (item.dataset.keywords || '').toLowerCase();
      const questionText = item.querySelector('.faq-q-text').textContent.toLowerCase();
      const answerText = item.querySelector('.faq-answer-inner').textContent.toLowerCase();

      const match = !q || keywords.includes(q) || questionText.includes(q) || answerText.includes(q);

      if (match) {
        item.classList.remove('faq-hidden');
        visibleCount++;
      } else {
        item.classList.add('faq-hidden');
        item.classList.remove('faq-open');
        item.querySelector('.faq-answer').style.maxHeight = '0';
      }
    });

    // Hide all section labels when searching
    labels.forEach(label => {
      label.style.display = q ? 'none' : '';
    });

    document.getElementById('noResults').classList.toggle('visible', visibleCount === 0);
  }
</script>

