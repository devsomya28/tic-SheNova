<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-container">

  <div class="page-hero">
    <div>
      <h2>Hello, <%= user.name %> 👋</h2>
      <p>Here's what your body is telling you today.</p>
    </div>
    <a href="/insights" class="btn-secondary">View insights →</a>
  </div>

  <!-- Flip cards row -->
  <% if (stats) { %>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:18px;">

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <div class="flip-icon">📅</div>
          <div>
            <div class="flip-title">Next period</div>
            <div class="flip-value" style="font-size:20px;">
              <%= stats.nextPeriod.toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %>
            </div>
          </div>
        </div>
        <div class="flip-card-back">
          <div class="flip-back-title">Next period</div>
          <div class="flip-back-text">
            Based on your average cycle of <%= stats.avg %> days.
            Predicted from your last <%= stats.totalLogs %> logged periods.
          </div>
          <div class="flip-back-hint">Hover to flip back</div>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <div class="flip-icon"><%= stats.phase.emoji %></div>
          <div>
            <div class="flip-title">Current phase</div>
            <div class="flip-value" style="font-size:22px;"><%= stats.phase.name %></div>
          </div>
        </div>
        <div class="flip-card-back">
          <div class="flip-back-title"><%= stats.phase.name %> phase</div>
          <div class="flip-back-text"><%= stats.phase.hormones %></div>
          <div class="flip-back-hint">Day <%= stats.dayOfCycle %> of <%= stats.avg %></div>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <div class="flip-icon">📊</div>
          <div>
            <div class="flip-title">Cycle length</div>
            <div class="flip-value"><%= stats.avg %> <span style="font-size:18px;">days</span></div>
          </div>
        </div>
        <div class="flip-card-back">
          <div class="flip-back-title">Cycle analysis</div>
          <div class="flip-back-text">
            <%= stats.isIrregular
              ? '⚠️ Your cycles vary by ' + stats.variance + ' days — worth discussing with a doctor.'
              : '✅ Your cycle length is within the normal range of 21–35 days.' %>
          </div>
          <div class="flip-back-hint">Range: <%= stats.min %>–<%= stats.max %> days</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Cycle Hero Card -->
  <div class="card cycle-hero">
    <div class="cycle-hero-top">
      <div>
        <div class="cycle-phase-pill">
          <%= stats.phase.emoji %> <%= stats.phase.name %> Phase
        </div>
        <h2 style="margin-top:12px; font-size:20px;">
          Day <%= stats.dayOfCycle %> of your cycle
        </h2>
        <p><%= stats.phase.tip %></p>
      </div>
      <div class="cycle-day-big">
        <div class="day-num"><%= stats.dayOfCycle %></div>
        <div class="day-label">day of cycle</div>
      </div>
    </div>

    <div class="cycle-progress-wrap">
      <div class="cycle-progress-bar">
        <div class="cycle-progress-fill"
          style="width:<%= Math.min(Math.round((stats.dayOfCycle/stats.avg)*100),100) %>%">
        </div>
      </div>
    </div>

    <div class="cycle-meta-row">
      <div class="cycle-meta-item">
        <strong><%= stats.nextPeriod.toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></strong>
        <span>Next period</span>
      </div>
      <div class="cycle-meta-item">
        <strong><%= stats.avg %> days</strong>
        <span>Average cycle</span>
      </div>
      <div class="cycle-meta-item">
        <strong><%= stats.totalLogs %></strong>
        <span>Cycles tracked</span>
      </div>
      <% if (stats.isIrregular) { %>
      <div class="cycle-meta-item" style="background:rgba(245,158,11,0.15);">
        <strong style="color:var(--amber);">⚠️ Irregular</strong>
        <span>Variance > 7 days</span>
      </div>
      <% } %>
    </div>
  </div>
  <% } else { %>

  <div class="card cycle-hero">
    <h2>Welcome to Herlytics! 🌸</h2>
    <p style="margin:12px 0 20px;">Log your first period below to start seeing your cycle insights.</p>
  </div>

  <% } %>

  <!-- Calendar Card -->
  <div class="card">
    <div class="calendar-header">
      <button class="cal-nav" id="prevMonth">‹</button>
      <h3 id="calMonthLabel">Loading...</h3>
      <button class="cal-nav" id="nextMonth">›</button>
    </div>

    <div class="calendar-wrap">
      <div class="calendar-grid" id="calDayNames"></div>
      <div class="calendar-grid" id="calGrid" style="margin-top:6px;"></div>
    </div>

   <div class="cal-legend">
  <div class="cal-legend-item">
    <div class="cal-dot" style="background:var(--rose);"></div> Period
  </div>
  <div class="cal-legend-item">
    <div class="cal-dot" style="background:#fff0f5;border:2px dashed #f48fb1;"></div> Predicted
  </div>
  <div class="cal-legend-item">
    <div class="cal-dot" style="background:#e8f5e9;border:1px solid #a5d6a7;"></div> Follicular
  </div>
  <div class="cal-legend-item">
    <div class="cal-dot" style="background:#fff9c4;border:1px solid #ffe082;"></div> Ovulation
  </div>
  <div class="cal-legend-item">
    <div class="cal-dot" style="background:#f3e5f5;border:1px solid #ce93d8;"></div> Luteal
  </div>
</div>

  <!-- Log Period -->
  <div class="card">
    <div class="card-title">Log a period</div>
    <div class="card-sub">Track your flow to build smarter insights</div>

    <form action="/dashboard/log" method="POST">
      <div class="log-form-grid">
        <div class="form-group" style="margin:0;">
          <label>Start date</label>
          <input type="date" name="periodStartDate" required />
        </div>

        <div class="form-group" style="margin:0;">
          <label>Mood today</label>
          <select name="mood">
            <option value="good">😊 Good</option>
            <option value="okay">😐 Okay</option>
            <option value="sad">😔 Low</option>
            <option value="tired">😴 Tired</option>
            <option value="nauseous">🤢 Nauseous</option>
          </select>
        </div>

        <div class="form-group" style="margin:0;">
          <label>Flow level</label>
          <select name="flowLevel">
            <option value="spotting">Spotting</option>
            <option value="light">Light</option>
            <option value="medium" selected>Medium</option>
            <option value="heavy">Heavy</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label>
          <input type="checkbox" name="hasClots" style="accent-color:var(--rose);">
          &nbsp;Clots present (larger than a coin) — important for tracking
        </label>
      </div>

      <button type="submit" class="btn-primary">Save log +</button>
    </form>
  </div>

  <!-- Recent logs -->
  <% if (logs.length > 0) { %>
  <div class="card">
    <div class="card-title">Recent logs</div>
    <div class="card-sub">Your last <%= Math.min(logs.length,5) %> entries</div>

    <div class="log-list">
      <% logs.slice(0,5).forEach(log => { %>
      <div class="log-item">
        <span class="log-date-badge">
          <%= log.periodStartDate.toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
        </span>

        <span class="log-flow flow-<%= log.flowLevel %>"><%= log.flowLevel %></span>

        <span class="log-mood">
          <%= log.mood === 'good' ? '😊' :
              log.mood === 'okay' ? '😐' :
              log.mood === 'sad' ? '😔' :
              log.mood === 'tired' ? '😴' : '🤢' %>
        </span>

        <% if (log.hasClots) { %>
        <span class="flag-sm">⚠️ clots</span>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>
  <a href="/blood/donate" class="btn-primary" style="background:#c0392b;">🩸 Donate Blood</a>
<a href="/blood/accept" class="btn-secondary">💉 Find Blood →</a>

</div>

<script>
const periodDates = <%- JSON.stringify(logs.map(l => l.periodStartDate)) %>;
const predictedNext = "<%= stats ? stats.nextPeriod.toISOString().split('T')[0] : '' %>";
const avgCycle = <%= stats ? stats.avg : 28 %>;
const periodDuration = parseInt("<%= user.periodDuration || '5' %>") || 5;

let currentDate = new Date();

function getPhaseForDate(date) {
  if (!periodDates.length) return null;

  // Find the most recent period start before or on this date
  const sorted = periodDates
    .map(d => new Date(d))
    .filter(d => d <= date)
    .sort((a, b) => b - a);

  if (!sorted.length) return null;

  const lastPeriod = sorted[0];
  const dayOfCycle = Math.floor((date - lastPeriod) / (1000 * 60 * 60 * 24)) + 1;

  if (dayOfCycle < 1 || dayOfCycle > avgCycle + 7) return null;

  if (dayOfCycle <= periodDuration)           return 'menstrual';
  if (dayOfCycle <= Math.round(avgCycle * 0.43)) return 'follicular';
  if (dayOfCycle <= Math.round(avgCycle * 0.57)) return 'ovulation';
  return 'luteal';
}

function renderCalendar(date) {
  const year  = date.getFullYear();
  const month = date.getMonth();
  const today = new Date();

  document.getElementById('calMonthLabel').textContent =
    date.toLocaleDateString('en-IN', { month: 'long', year: 'numeric' });

  const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  document.getElementById('calDayNames').innerHTML =
    dayNames.map(d => `<div class="cal-day-name">${d}</div>`).join('');

  const firstDay    = new Date(year, month, 1).getDay();
  const daysInMonth = new Date(year, month + 1, 0).getDate();

  const periodSet = new Set(periodDates.map(d => new Date(d).toDateString()));

  const predictedDates = new Set();
  if (predictedNext) {
    const base = new Date(predictedNext);
    for (let i = 0; i < periodDuration; i++) {
      const d = new Date(base);
      d.setDate(base.getDate() + i);
      predictedDates.add(d.toDateString());
    }
  }

  let html = '';
  for (let i = 0; i < firstDay; i++) html += `<div class="cal-day empty"></div>`;

  for (let d = 1; d <= daysInMonth; d++) {
    const thisDate  = new Date(year, month, d);
    const isToday   = thisDate.toDateString() === today.toDateString();
    const isPeriod  = periodSet.has(thisDate.toDateString());
    const isPredicted = predictedDates.has(thisDate.toDateString());
    const phase     = getPhaseForDate(thisDate);

    let cls   = 'cal-day';
    let style = '';
    let title = '';

    if (isPeriod) {
      cls += ' period';
      title = 'Period day';
    } else if (isPredicted) {
      cls += ' predicted';
      title = 'Predicted period';
    } else if (phase === 'follicular') {
      style = 'background:#e8f5e9;color:#2e7d32;';
      title = 'Follicular phase';
    } else if (phase === 'ovulation') {
      style = 'background:#fff9c4;color:#f57f17;font-weight:700;';
      title = 'Ovulation window';
    } else if (phase === 'luteal') {
      style = 'background:#f3e5f5;color:#6a1b9a;';
      title = 'Luteal phase';
    }

    if (isToday) {
      cls += ' today';
      style += 'outline:2px solid var(--rose);outline-offset:-2px;';
    }

    html += `<div class="${cls}" style="${style}" title="${title}">${d}</div>`;
  }

  document.getElementById('calGrid').innerHTML = html;
}

document.getElementById('prevMonth').addEventListener('click', () => {
  currentDate = new Date(currentDate.getFullYear(), currentDate.getMonth() - 1, 1);
  renderCalendar(currentDate);
});
document.getElementById('nextMonth').addEventListener('click', () => {
  currentDate = new Date(currentDate.getFullYear(), currentDate.getMonth() + 1, 1);
  renderCalendar(currentDate);
});

renderCalendar(currentDate);
</script>
<%- include('partials/footer') %>