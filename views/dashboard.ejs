<%- include('partials/header') %>
<%- include('partials/navbar') %>

<style>
:root {
  --lav-50:#f5f0ff;--lav-100:#ede5ff;--lav-200:#d9ccff;--lav-300:#bfa8ff;
  --lav-400:#a080ff;--lav-500:#8b5cf6;--lav-600:#7c3aed;--lav-700:#6d28d9;
  --lav-800:#5b21b6;--rose:#f472b6;--rose-lt:#fce7f3;--amber:#f59e0b;
  --bg:#faf8ff;--surface:#fff;--border:#e8deff;--text:#2d1b5e;--text-muted:#7c6fa0;
  --shadow:0 4px 24px rgba(139,92,246,0.10);--radius:16px;--radius-sm:10px;
}
*,*::before,*::after{box-sizing:border-box;}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);}
.page-container{max-width:860px;margin:0 auto;padding:2rem 1.5rem;}

/* cards */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);margin-bottom:1.25rem;}
.card-title{font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:0.25rem;}
.card-sub{font-size:0.8rem;color:var(--text-muted);margin-bottom:1rem;}

/* hero banner */
.page-hero{display:flex;align-items:center;justify-content:space-between;gap:1rem;background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;border-radius:var(--radius);padding:1.5rem 2rem;margin-bottom:1.5rem;}
.page-hero h2{font-size:1.4rem;font-weight:800;margin-bottom:0.25rem;}
.page-hero p{opacity:0.85;font-size:0.9rem;}

/* flip cards */
.flip-cards-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.25rem;}
.flip-card{height:150px;cursor:pointer;perspective:1000px;}
.flip-card-inner{position:relative;width:100%;height:100%;transition:transform 0.55s cubic-bezier(0.4,0,0.2,1);transform-style:preserve-3d;}
.flip-card:hover .flip-card-inner{transform:rotateY(180deg);}
.flip-card-front,.flip-card-back{position:absolute;inset:0;backface-visibility:hidden;border-radius:var(--radius);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1rem;text-align:center;border:1px solid var(--border);}
.flip-card-front{background:var(--surface);box-shadow:var(--shadow);}
.flip-card-back{background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;transform:rotateY(180deg);}
.flip-icon{font-size:1.8rem;margin-bottom:0.4rem;}
.flip-title{font-size:0.82rem;font-weight:600;color:var(--text-muted);}
.flip-value{font-size:1.3rem;font-weight:800;color:var(--text);}
.flip-back-title{font-size:0.75rem;font-weight:600;opacity:0.8;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.3rem;}
.flip-back-text{font-size:0.8rem;opacity:0.9;line-height:1.5;}
.flip-back-hint{font-size:0.7rem;opacity:0.7;margin-top:0.4rem;}

/* cycle hero */
.cycle-hero{background:linear-gradient(135deg,var(--lav-50),#fff9ff);border:1.5px solid var(--lav-200);}
.cycle-hero-top{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;margin-bottom:1rem;}
.cycle-phase-pill{display:inline-flex;align-items:center;gap:0.4rem;background:var(--lav-100);color:var(--lav-800);padding:0.3rem 0.9rem;border-radius:99px;font-size:0.8rem;font-weight:600;margin-bottom:0.5rem;}
.cycle-day-big{text-align:center;background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;border-radius:var(--radius);padding:1rem 1.5rem;min-width:90px;}
.day-num{font-size:2.5rem;font-weight:900;line-height:1;}
.day-label{font-size:0.7rem;opacity:0.8;text-transform:uppercase;letter-spacing:0.05em;}
.cycle-progress-wrap{margin-bottom:1rem;}
.cycle-progress-bar{background:var(--lav-100);border-radius:99px;height:8px;overflow:hidden;}
.cycle-progress-fill{height:100%;background:linear-gradient(90deg,var(--lav-400),var(--lav-600));border-radius:99px;transition:width 1s ease;}
.cycle-meta-row{display:flex;gap:0.75rem;flex-wrap:wrap;}
.cycle-meta-item{background:var(--lav-50);border-radius:var(--radius-sm);padding:0.6rem 0.9rem;display:flex;flex-direction:column;gap:2px;border:1px solid var(--lav-200);}
.cycle-meta-item strong{font-size:0.95rem;font-weight:700;color:var(--lav-700);}
.cycle-meta-item span{font-size:0.72rem;color:var(--text-muted);}

/* calendar */
.calendar-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;}
.cal-nav{background:var(--lav-50);border:1px solid var(--lav-200);border-radius:8px;padding:4px 12px;font-size:0.85rem;cursor:pointer;color:var(--lav-700);font-weight:600;transition:background 0.2s;}
.cal-nav:hover{background:var(--lav-100);}
.calendar-wrap{overflow:hidden;}
.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.cal-day-name{text-align:center;font-size:0.7rem;font-weight:600;color:var(--text-muted);padding:4px 0;}
.cal-day{text-align:center;font-size:0.78rem;padding:6px 2px;border-radius:6px;cursor:pointer;color:var(--text);transition:all 0.15s;}
.cal-day:hover{background:var(--lav-100);color:var(--lav-700);}
.cal-day.today{background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;font-weight:700;border-radius:50%;}
.cal-day.period{background:var(--rose-lt);color:#be185d;font-weight:700;border-radius:50%;}
.cal-day.predicted{background:#fff0f5;border:2px dashed #f48fb1;border-radius:50%;color:#be185d;}
.cal-day.empty{cursor:default;}
.cal-legend{display:flex;gap:1rem;margin-top:0.75rem;flex-wrap:wrap;}
.cal-legend-item{display:flex;align-items:center;gap:5px;font-size:0.72rem;color:var(--text-muted);}
.cal-dot{width:10px;height:10px;border-radius:50%;}

/* log form */
.log-form-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1rem;}
.form-group{margin-bottom:1rem;}
label{display:block;font-size:0.82rem;font-weight:600;color:var(--text);margin-bottom:0.4rem;}
input[type=date],input[type=text],select{width:100%;padding:0.7rem 1rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:inherit;font-size:0.9rem;background:var(--surface);color:var(--text);outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
input:focus,select:focus{border-color:var(--lav-400);box-shadow:0 0 0 3px rgba(139,92,246,0.12);}
input[type=checkbox]{accent-color:var(--lav-500);}

/* buttons */
.btn-primary{display:inline-flex;align-items:center;gap:0.5rem;padding:0.65rem 1.4rem;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;border:none;text-decoration:none;background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;box-shadow:0 2px 12px rgba(139,92,246,0.3);transition:all 0.22s;}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 18px rgba(139,92,246,0.4);}
.btn-secondary{display:inline-flex;align-items:center;padding:0.5rem 1.1rem;border-radius:8px;font-size:0.85rem;font-weight:600;text-decoration:none;background:rgba(255,255,255,0.2);color:white;border:1.5px solid rgba(255,255,255,0.5);transition:all 0.2s;}
.btn-secondary:hover{background:rgba(255,255,255,0.35);}

/* log list */
.log-list{display:flex;flex-direction:column;gap:0.6rem;}
.log-item{display:flex;align-items:center;gap:0.75rem;padding:0.7rem 1rem;background:var(--lav-50);border-radius:var(--radius-sm);border:1px solid var(--lav-100);}
.log-date-badge{font-size:0.8rem;font-weight:600;color:var(--lav-700);background:var(--lav-100);padding:0.25rem 0.6rem;border-radius:99px;}
.log-flow{font-size:0.75rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:99px;background:#e8f5e9;color:#2e7d32;}
.log-flow.heavy{background:#fce4ec;color:#c62828;}
.log-flow.light{background:#e8f5e9;color:#2e7d32;}
.log-flow.spotting{background:#fff3e0;color:#e65100;}
.log-mood{font-size:1.1rem;}
.flag-sm{font-size:0.72rem;background:var(--rose-lt);color:#c62828;padding:0.2rem 0.5rem;border-radius:99px;font-weight:600;}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
.fade-up{animation:fadeUp 0.45s ease both;}
@media(max-width:640px){.flip-cards-row{grid-template-columns:1fr;}.log-form-grid{grid-template-columns:1fr;}}
</style>

<div class="page-container">

  <!-- Hero -->
  <div class="page-hero fade-up">
    <div>
      <h2>Hello, <%= user.name %> 👋</h2>
      <p>Here's what your body is telling you today.</p>
    </div>
    <a href="/insights" class="btn-secondary">View insights →</a>
  </div>

  <!-- Flip Cards -->
  <% if (stats) { %>
  <div class="flip-cards-row fade-up">

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <div class="flip-icon">📅</div>
          <div class="flip-title">Next period</div>
          <div class="flip-value" style="font-size:1.1rem;">
            <%= stats.nextPeriod.toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %>
          </div>
        </div>
        <div class="flip-card-back">
          <div class="flip-back-title">Next period</div>
          <div class="flip-back-text">Based on your avg cycle of <%= stats.avg %> days. Predicted from your last <%= stats.totalLogs %> periods.</div>
          <div class="flip-back-hint">Hover to flip back</div>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <div class="flip-icon"><%= stats.phase.emoji %></div>
          <div class="flip-title">Current phase</div>
          <div class="flip-value"><%= stats.phase.name %></div>
        </div>
        <div class="flip-card-back">
          <div class="flip-back-title"><%= stats.phase.name %> phase</div>
          <div class="flip-back-text"><%= stats.phase.hormones %></div>
          <div class="flip-back-hint">Day <%= stats.dayOfCycle %> of <%= stats.avg %></div>
        </div>
      </div>
    </div>

    <div class="flip-card">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <div class="flip-icon">📊</div>
          <div class="flip-title">Cycle length</div>
          <div class="flip-value"><%= stats.avg %> <span style="font-size:0.9rem;font-weight:500;">days</span></div>
        </div>
        <div class="flip-card-back">
          <div class="flip-back-title">Cycle analysis</div>
          <div class="flip-back-text">
            <%= stats.isIrregular ? '⚠️ Your cycles vary by ' + stats.variance + ' days — worth discussing with a doctor.' : '✅ Your cycle length is within the normal range of 21–35 days.' %>
          </div>
          <div class="flip-back-hint">Range: <%= stats.min %>–<%= stats.max %> days</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Cycle Hero Card -->
  <div class="card cycle-hero fade-up">
    <div class="cycle-hero-top">
      <div>
        <div class="cycle-phase-pill"><%= stats.phase.emoji %> <%= stats.phase.name %> Phase</div>
        <h2 style="margin-top:8px;font-size:1.15rem;font-weight:800;">Day <%= stats.dayOfCycle %> of your cycle</h2>
        <p style="font-size:0.88rem;color:var(--text-muted);margin-top:4px;"><%= stats.phase.tip %></p>
      </div>
      <div class="cycle-day-big">
        <div class="day-num"><%= stats.dayOfCycle %></div>
        <div class="day-label">day of cycle</div>
      </div>
    </div>

    <div class="cycle-progress-wrap">
      <div class="cycle-progress-bar">
        <div class="cycle-progress-fill" style="width:<%= Math.min(Math.round((stats.dayOfCycle/stats.avg)*100),100) %>%"></div>
      </div>
    </div>

    <div class="cycle-meta-row">
      <div class="cycle-meta-item">
        <strong><%= stats.nextPeriod.toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></strong>
        <span>Next period</span>
      </div>
      <div class="cycle-meta-item">
        <strong><%= stats.avg %> days</strong>
        <span>Average cycle</span>
      </div>
      <div class="cycle-meta-item">
        <strong><%= stats.totalLogs %></strong>
        <span>Cycles tracked</span>
      </div>
      <% if (stats.isIrregular) { %>
      <div class="cycle-meta-item" style="background:rgba(245,158,11,0.1);border-color:var(--amber);">
        <strong style="color:var(--amber);">⚠️ Irregular</strong>
        <span>Variance > 7 days</span>
      </div>
      <% } %>
    </div>
  </div>
  <% } else { %>

  <div class="card cycle-hero fade-up" style="text-align:center;padding:2.5rem;">
    <div style="font-size:3rem;margin-bottom:1rem;">🌸</div>
    <h2 style="font-size:1.3rem;font-weight:800;margin-bottom:0.5rem;">Welcome to Herlytics!</h2>
    <p style="color:var(--text-muted);margin-bottom:1.25rem;">Log your first period below to start seeing your cycle insights.</p>
  </div>

  <% } %>

  <!-- Calendar -->
  <div class="card fade-up">
    <div class="calendar-header">
      <button class="cal-nav" id="prevMonth">‹</button>
      <h3 id="calMonthLabel" style="font-size:1rem;font-weight:700;color:var(--lav-700);">Loading...</h3>
      <button class="cal-nav" id="nextMonth">›</button>
    </div>
    <div class="calendar-wrap">
      <div class="calendar-grid" id="calDayNames"></div>
      <div class="calendar-grid" id="calGrid" style="margin-top:6px;"></div>
    </div>
    <div class="cal-legend">
      <div class="cal-legend-item"><div class="cal-dot" style="background:linear-gradient(135deg,var(--lav-500),var(--lav-700));"></div> Today</div>
      <div class="cal-legend-item"><div class="cal-dot" style="background:var(--rose-lt);border:2px solid #f48fb1;"></div> Period logged</div>
      <div class="cal-legend-item"><div class="cal-dot" style="background:#fff0f5;border:2px dashed #f48fb1;"></div> Predicted</div>
    </div>
  </div>

  <!-- Log Period -->
  <div class="card fade-up">
    <div class="card-title">Log a period</div>
    <div class="card-sub">Track your flow to build smarter insights</div>

    <form action="/dashboard/log" method="POST">
      <div class="log-form-grid">
        <div class="form-group" style="margin:0;">
          <label>Start date</label>
          <input type="date" name="periodStartDate" required />
        </div>
        <div class="form-group" style="margin:0;">
          <label>Mood today</label>
          <select name="mood">
            <option value="good">😊 Good</option>
            <option value="okay">😐 Okay</option>
            <option value="sad">😔 Low</option>
            <option value="tired">😴 Tired</option>
            <option value="nauseous">🤢 Nauseous</option>
          </select>
        </div>
        <div class="form-group" style="margin:0;">
          <label>Flow level</label>
          <select name="flowLevel">
            <option value="spotting">Spotting</option>
            <option value="light">Light</option>
            <option value="medium" selected>Medium</option>
            <option value="heavy">Heavy</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>
          <input type="checkbox" name="hasClots">
          &nbsp;Clots present (larger than a coin) — important for tracking
        </label>
      </div>
      <button type="submit" class="btn-primary">Save log +</button>
    </form>
  </div>

  <!-- Recent Logs -->
  <% if (logs.length > 0) { %>
  <div class="card fade-up">
    <div class="card-title">Recent logs</div>
    <div class="card-sub">Your last <%= Math.min(logs.length,5) %> entries</div>
    <div class="log-list">
      <% logs.slice(0,5).forEach(log => { %>
      <div class="log-item">
        <span class="log-date-badge">
          <%= log.periodStartDate.toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
        </span>
        <span class="log-flow flow-<%= log.flowLevel %>"><%= log.flowLevel %></span>
        <span class="log-mood">
          <%= log.mood === 'good' ? '😊' : log.mood === 'okay' ? '😐' : log.mood === 'sad' ? '😔' : log.mood === 'tired' ? '😴' : '🤢' %>
        </span>
        <% if (log.hasClots) { %><span class="flag-sm">⚠️ clots</span><% } %>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>

</div>

<script>
const periodDates = <%- JSON.stringify(logs.map(l => l.periodStartDate)) %>;
const predictedNext = "<%= stats ? stats.nextPeriod.toISOString().split('T')[0] : '' %>";
let currentDate = new Date();

function renderCalendar(date) {
  const year = date.getFullYear(), month = date.getMonth(), today = new Date();
  document.getElementById('calMonthLabel').textContent = date.toLocaleDateString('en-IN',{month:'long',year:'numeric'});
  const dayNames = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  document.getElementById('calDayNames').innerHTML = dayNames.map(d=>`<div class="cal-day-name">${d}</div>`).join('');
  const firstDay = new Date(year,month,1).getDay();
  const daysInMonth = new Date(year,month+1,0).getDate();
  const periodSet = new Set(periodDates.map(d => new Date(d).toDateString()));
  let html = '';
  for(let i=0;i<firstDay;i++) html += `<div class="cal-day empty"></div>`;
  for(let d=1;d<=daysInMonth;d++){
    const thisDate = new Date(year,month,d);
    const isToday = thisDate.toDateString()===today.toDateString();
    const isPeriod = periodSet.has(thisDate.toDateString());
    const isPredicted = predictedNext && thisDate.toDateString()===new Date(predictedNext).toDateString();
    let cls='cal-day';
    if(isToday) cls+=' today';
    else if(isPeriod) cls+=' period';
    else if(isPredicted) cls+=' predicted';
    html += `<div class="${cls}">${d}</div>`;
  }
  document.getElementById('calGrid').innerHTML = html;
}

document.getElementById('prevMonth').addEventListener('click',()=>{ currentDate=new Date(currentDate.getFullYear(),currentDate.getMonth()-1,1); renderCalendar(currentDate); });
document.getElementById('nextMonth').addEventListener('click',()=>{ currentDate=new Date(currentDate.getFullYear(),currentDate.getMonth()+1,1); renderCalendar(currentDate); });
renderCalendar(currentDate);
</script>

<%- include('partials/footer') %>
