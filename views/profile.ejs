<%- include('partials/header') %>
<%- include('partials/navbar') %>

<style>
:root{--lav-50:#f5f0ff;--lav-100:#ede5ff;--lav-200:#d9ccff;--lav-300:#bfa8ff;--lav-400:#a080ff;--lav-500:#8b5cf6;--lav-600:#7c3aed;--lav-700:#6d28d9;--bg:#faf8ff;--surface:#fff;--border:#e8deff;--text:#2d1b5e;--text-muted:#7c6fa0;--shadow:0 4px 24px rgba(139,92,246,0.10);--radius:16px;--radius-sm:10px;--amber:#f59e0b;}
*,*::before,*::after{box-sizing:border-box;}
body{font-family:'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--text);}
.page-container{max-width:760px;margin:0 auto;padding:2rem 1.5rem;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);margin-bottom:1.25rem;}
.card-title{font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:0.2rem;}
.card-sub{font-size:0.8rem;color:var(--text-muted);margin-bottom:1.25rem;}
.page-hero{background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;border-radius:var(--radius);padding:1.5rem 2rem;margin-bottom:1.5rem;}
.page-hero h2{font-size:1.4rem;font-weight:800;margin-bottom:0.25rem;}
.page-hero p{opacity:0.85;font-size:0.9rem;}

/* alerts */
.alert{padding:0.85rem 1.1rem;border-radius:var(--radius-sm);font-size:0.88rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.6rem;}
.alert-success{background:#e8f5e9;color:#2e7d32;border:1px solid #a5d6a7;}
.alert-danger{background:#fce4ec;color:#c62828;border:1px solid #f48fb1;}

/* form */
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.form-group{margin-bottom:1.1rem;}
label{display:block;font-size:0.82rem;font-weight:600;color:var(--text);margin-bottom:0.4rem;}
.hint{font-size:0.72rem;color:var(--text-muted);font-weight:400;}
input[type=text],input[type=number],input[type=email],input[type=password]{width:100%;padding:0.7rem 1rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:inherit;font-size:0.9rem;background:var(--surface);color:var(--text);outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
input:focus{border-color:var(--lav-400);box-shadow:0 0 0 3px rgba(139,92,246,0.12);}
input:disabled{background:#f5f5f5;color:#aaa;cursor:not-allowed;}

/* radio/checkbox groups */
.radio-group,.checkbox-group{display:flex;flex-direction:column;gap:0.4rem;margin-top:0.5rem;}
.radio-group label,.checkbox-group label{display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;font-weight:400;color:var(--text);cursor:pointer;padding:0.5rem 0.75rem;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);transition:all 0.18s;}
.radio-group label:hover,.checkbox-group label:hover{border-color:var(--lav-400);background:var(--lav-50);}
input[type=radio],input[type=checkbox]{accent-color:var(--lav-500);}

/* age insight box */
.age-insight-box{border-radius:var(--radius-sm);padding:1rem 1.1rem;margin-bottom:1.1rem;display:flex;flex-direction:column;gap:0.3rem;border-left:4px solid var(--lav-500);background:var(--lav-50);}
.age-tag{display:inline-block;padding:0.2rem 0.6rem;border-radius:99px;font-size:0.75rem;font-weight:700;margin-bottom:0.3rem;}
.age-peri{background:#f3e8ff;color:#7c3aed;}
.age-pre{background:#fff3e0;color:#e65100;}
.age-teen{background:#e8f5e9;color:#2e7d32;}
.age-normal{background:var(--lav-100);color:var(--lav-700);}
.age-insight-box p{font-size:0.83rem;color:var(--text-muted);line-height:1.6;}

/* btn */
.btn-primary{display:inline-flex;align-items:center;gap:0.5rem;padding:0.65rem 1.6rem;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;border:none;text-decoration:none;background:linear-gradient(135deg,var(--lav-500),var(--lav-700));color:white;box-shadow:0 2px 12px rgba(139,92,246,0.3);transition:all 0.22s;margin-top:0.5rem;}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 18px rgba(139,92,246,0.4);}

@keyframes fadeUp{from{opacity:0;transform:translateY(18px);}to{opacity:1;transform:translateY(0);}}
.fade-up{animation:fadeUp 0.45s ease both;}
@media(max-width:600px){.form-row{grid-template-columns:1fr;}}
</style>

<div class="page-container">

  <div class="page-hero fade-up">
    <h2>Your profile</h2>
    <p>Update your information and health answers anytime.</p>
  </div>

  <% if (success) { %>
  <div class="alert alert-success">✅ <%= success %></div>
  <% } %>
  <% if (error) { %>
  <div class="alert alert-danger">⚠️ <%= error %></div>
  <% } %>

  <!-- Basic Info -->
  <div class="card fade-up">
    <div class="card-title">Basic information</div>
    <div class="card-sub">Name, age and city</div>

    <form action="/profile/update" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Full name</label>
          <input type="text" name="name" value="<%= user.name %>" required />
        </div>
        <div class="form-group">
          <label>Username</label>
          <input type="text" value="@<%= user.username %>" disabled />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Age <span class="hint">— helps personalise menopause insights</span></label>
          <input type="number" name="age" min="10" max="65" value="<%= user.age || '' %>" placeholder="e.g. 24" />
        </div>
        <div class="form-group">
          <label>City</label>
          <input type="text" name="city" value="<%= user.city || '' %>" placeholder="e.g. Bhopal" />
        </div>
      </div>

      <% if (user.age) { %>
      <div class="age-insight-box">
        <% if (user.age >= 45) { %>
          <span class="age-tag age-peri">🌙 Perimenopause range</span>
          <p>At age <%= user.age %>, you may be entering perimenopause. Irregular cycles, hot flashes, and mood changes are common. This is a natural transition — not a disease. We'll flag relevant patterns in your insights.</p>
        <% } else if (user.age >= 40) { %>
          <span class="age-tag age-pre">⏳ Pre-perimenopause watch</span>
          <p>At age <%= user.age %>, your hormones may begin shifting over the next few years. We'll watch your cycle patterns closely and flag any changes.</p>
        <% } else if (user.age <= 17) { %>
          <span class="age-tag age-teen">🌱 Teen cycle</span>
          <p>At age <%= user.age %>, irregular cycles are completely normal. It can take 2–3 years after your first period for cycles to regulate. We'll let you know what's normal for your age.</p>
        <% } else { %>
          <span class="age-tag age-normal">✅ Reproductive years</span>
          <p>At age <%= user.age %>, you're in your reproductive years. A healthy cycle is 21–35 days. We'll track your patterns and flag anything worth discussing with a doctor.</p>
        <% } %>
      </div>
      <% } %>

      <button type="submit" class="btn-primary">Save changes</button>
    </form>
  </div>

  <!-- Health Profile -->
  <div class="card fade-up">
    <div class="card-title">Your health profile</div>
    <div class="card-sub">Update your symptoms and lifestyle answers — this improves your risk analysis</div>

    <form action="/profile/health" method="POST">

      <div class="form-group">
        <label>How many days between your periods?</label>
        <div class="radio-group">
          <% ['less21','21-25','26-30','31-35','more35','irregular'].forEach(val => { %>
          <% const labels = {'less21':'Less than 21 days','21-25':'21–25 days','26-30':'26–30 days','31-35':'31–35 days','more35':'More than 35 days','irregular':'Completely irregular'} %>
          <label>
            <input type="radio" name="cycleGap" value="<%= val %>" <%= user.cycleGap === val ? 'checked' : '' %> required>
            <%= labels[val] %>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Physical symptoms</label>
        <div class="checkbox-group">
          <% const physOpts = [
            {v:'cramps',l:'Cramps / pelvic pain'},{v:'heavy_flow',l:'Very heavy bleeding'},
            {v:'clots',l:'Clots in flow (larger than a coin)'},{v:'spotting',l:'Bleeding between periods'},
            {v:'bloating',l:'Bloating'},{v:'headaches',l:'Headaches / migraines'},
            {v:'nausea',l:'Nausea'},{v:'back_pain',l:'Back pain'},
            {v:'facial_hair',l:'Unusual facial hair / acne'},
          ] %>
          <% physOpts.forEach(o => { %>
          <label>
            <input type="checkbox" name="physicalSymptoms" value="<%= o.v %>" <%= user.physicalSymptoms && user.physicalSymptoms.includes(o.v) ? 'checked' : '' %>>
            <%= o.l %>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Emotional symptoms</label>
        <div class="checkbox-group">
          <% const emoOpts = [
            {v:'mood_swings',l:'Mood swings'},{v:'anxiety',l:'Anxiety before period'},
            {v:'depression',l:'Depression during period'},{v:'fatigue',l:'Extreme fatigue'},
            {v:'brain_fog',l:'Brain fog / forgetfulness'},
          ] %>
          <% emoOpts.forEach(o => { %>
          <label>
            <input type="checkbox" name="emotionalSymptoms" value="<%= o.v %>" <%= user.emotionalSymptoms && user.emotionalSymptoms.includes(o.v) ? 'checked' : '' %>>
            <%= o.l %>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Stress level</label>
        <div class="radio-group">
          <% [['low','Low — fairly calm'],['moderate','Moderate — manageable'],['high','High — exams / work pressure'],['very_high','Very high — overwhelmed']].forEach(([v,l]) => { %>
          <label>
            <input type="radio" name="stressLevel" value="<%= v %>" <%= user.stressLevel === v ? 'checked' : '' %>>
            <%= l %>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Sleep pattern</label>
        <div class="radio-group">
          <% [['good','Regular 7–8 hours'],['moderate','Irregular but okay'],['poor','Poor, often tired'],['very_poor','Very disrupted']].forEach(([v,l]) => { %>
          <label>
            <input type="radio" name="sleepPattern" value="<%= v %>" <%= user.sleepPattern === v ? 'checked' : '' %>>
            <%= l %>
          </label>
          <% }) %>
        </div>
      </div>

      <div class="form-group">
        <label>Known health conditions</label>
        <div class="checkbox-group">
          <% [['pcos','PCOS'],['thyroid','Thyroid'],['endometriosis','Endometriosis'],['anaemia','Anaemia'],['diabetes','Diabetes'],['none','None']].forEach(([v,l]) => { %>
          <label>
            <input type="checkbox" name="knownConditions" value="<%= v %>" <%= user.knownConditions && user.knownConditions.includes(v) ? 'checked' : '' %>>
            <%= l %>
          </label>
          <% }) %>
        </div>
      </div>

      <button type="submit" class="btn-primary">Update health profile</button>
    </form>
  </div>

</div>

<%- include('partials/footer') %>
