<%- include('../partials/header') %>

<div class="onboarding-page">
  <div class="onboarding-card">
    <div class="progress-bar">
      <div class="progress-fill" style="width: 100%"></div>
    </div>
    <p class="stage-label">Stage 5 of 5 — Your health network</p>
    <h2>Let's connect you to real help when needed.</h2>

    <form action="/onboarding/stage5" method="POST">

      <div class="form-group">
        <label>Do you have a doctor you currently consult?</label>
        <div class="radio-group">
          <label><input type="radio" name="hasDoctorAccess" value="yes" required> Yes — I have a gynecologist</label>
          <label><input type="radio" name="hasDoctorAccess" value="sometimes"> Sometimes — when needed</label>
          <label><input type="radio" name="hasDoctorAccess" value="no"> No — I don't have access</label>
          <label><input type="radio" name="hasDoctorAccess" value="never"> I've never visited one</label>
        </div>
      </div>

      <div class="form-group">
        <label>Your city <span class="hint">(optional — to find nearby doctors)</span></label>
        <input type="text" name="city" placeholder="e.g. Bhopal, Mumbai, Delhi" />
      </div>

      <button type="submit" class="btn-primary">Take me to my dashboard →</button>

    </form>
  </div>
</div>

<%- include('../partials/footer') %>