<%- include('../partials/header') %>
<div class="onboarding-page">
  <div class="progress-bar"><div class="progress-fill" style="width:80%"></div></div>
  <p class="progress-text">Stage 4 of 5 — Past Cycles</p>
  <div class="onboarding-card">
    <h2>3 past dates = 3x smarter insights.</h2>
    <p class="hint-text">Only have 1 or 2? That's fine. Leave the rest blank.</p>
    <form action="/onboarding/stage4" method="POST">
      <div class="form-group">
        <label>Most recent period start date</label>
        <input type="date" name="date1" />
      </div>
      <div class="form-group">
        <label>Period before that</label>
        <input type="date" name="date2" />
      </div>
      <div class="form-group">
        <label>One more before that</label>
        <input type="date" name="date3" />
      </div>
      <button type="submit" class="btn-primary">Next →</button>
      <a href="/onboarding/stage5" class="btn-skip">Skip — I don't remember</a>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>