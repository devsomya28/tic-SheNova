<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="page-container">

  <div class="card">
    <h2 class="page-title">Find a gynecologist near you</h2>
    <p class="page-sub">Real doctors. Real help. Near you.</p>

    <form action="/doctor" method="GET" class="search-form">
      <div class="search-row">
        <input type="text" name="city" value="<%= cityQuery %>"
          placeholder="Enter your city — e.g. Bhopal, Indore, Mumbai" class="search-input" />
        <button type="submit" class="btn-primary">Search</button>
      </div>
    </form>
  </div>

  <% if (clinics.length > 0) { %>

  <div class="section-title">
    <span class="section-dot"></span>
    <%= clinics.length %> doctors found near <%= cityQuery %>
  </div>

  <div class="doctor-grid">
    <% clinics.forEach((clinic, index) => { %>
    <div
      class="doctor-card <%= index === 0 ? 'active-doctor' : '' %>"
      onclick="selectDoctor(this, <%= clinic.lat || lat %>, <%= clinic.lng || lng %>, '<%= clinic.name.replace(/'/g, "\\'") %>', '<%= clinic.area.replace(/'/g, "\\'") %>')"
      data-lat="<%= clinic.lat || lat %>"
      data-lng="<%= clinic.lng || lng %>"
      data-name="<%= clinic.name %>"
      data-area="<%= clinic.area %>"
    >
      <div class="doctor-avatar"><%= clinic.name.charAt(3) %></div>
      <div class="doctor-info">
        <h3 class="doctor-name"><%= clinic.name %></h3>
        <span class="doctor-specialty"><%= clinic.specialty %></span>
        <div class="doctor-details">
          <div class="doctor-detail-row">
            <span class="detail-icon">🏥</span>
            <span><%= clinic.hospital %></span>
          </div>
          <div class="doctor-detail-row">
            <span class="detail-icon">📍</span>
            <span><%= clinic.address %></span>
          </div>
          <div class="doctor-detail-row">
            <span class="detail-icon">📞</span>
            <span><%= clinic.phone %></span>
          </div>
        </div>
        <div class="doctor-actions">
          <a href="tel:<%= clinic.phone %>" class="btn-call" onclick="event.stopPropagation()">Call Now</a>
          <span class="area-badge"><%= clinic.area %></span>
        </div>
      </div>

      <!-- Selected indicator -->
      <div class="selected-indicator">📍 Showing on map</div>
    </div>
    <% }) %>
  </div>

  <!-- Map Section — updates dynamically when a doctor is clicked -->
  <% if (lat && lng) { %>
  <div class="card map-card" id="map-card">
    <div class="map-header">
      <h3 id="map-title">📍 <span id="map-doctor-name"><%= clinics[0] ? clinics[0].name : cityQuery %></span></h3>
      <span id="map-area-badge" class="map-area-label"><%= clinics[0] ? clinics[0].area : cityQuery %></span>
    </div>

    <iframe
      id="map-frame"
      width="100%"
      height="400"
      style="border:none; border-radius:12px; margin-top:14px;"
      src="https://www.openstreetmap.org/export/embed.html?bbox=<%= (clinics[0] ? (clinics[0].lng || lng) : lng) - 0.015 %>,<%= (clinics[0] ? (clinics[0].lat || lat) : lat) - 0.015 %>,<%= (clinics[0] ? (clinics[0].lng || lng) : lng) + 0.015 %>,<%= (clinics[0] ? (clinics[0].lat || lat) : lat) + 0.015 %>&layer=mapnik&marker=<%= clinics[0] ? (clinics[0].lat || lat) : lat %>,<%= clinics[0] ? (clinics[0].lng || lng) : lng %>"
    ></iframe>

    <a id="map-open-link"
      href="https://www.openstreetmap.org/?mlat=<%= clinics[0] ? (clinics[0].lat || lat) : lat %>&mlon=<%= clinics[0] ? (clinics[0].lng || lng) : lng %>#map=16/<%= clinics[0] ? (clinics[0].lat || lat) : lat %>/<%= clinics[0] ? (clinics[0].lng || lng) : lng %>"
      target="_blank" class="map-link">Open full map →</a>
  </div>
  <% } %>

  <% } else if (cityQuery) { %>
  <div class="card empty-card">
    <div class="empty-icon">🔍</div>
    <h3>No results for "<%= cityQuery %>"</h3>
    <p>We currently have data for Bhopal and Indore. More cities coming soon.</p>
    <p style="margin-top:8px; font-size:13px; color:#aaa;">Try searching "Bhopal" or "Indore"</p>
  </div>
  <% } %>

  <!-- Free resources -->
  <div class="card resources-card">
    <h3 class="resources-title">Free government health resources</h3>
    <div class="resources-grid">
      <div class="resource-item">
        <div class="resource-icon">🏛️</div>
        <div>
          <strong>PMJAY — Ayushman Bharat</strong>
          <p>Free health coverage up to ₹5 lakh/year for eligible families.</p>
        </div>
      </div>
      <div class="resource-item">
        <div class="resource-icon">🤱</div>
        <div>
          <strong>Janani Suraksha Yojana</strong>
          <p>Free maternal health at all government hospitals.</p>
        </div>
      </div>
      <div class="resource-item">
        <div class="resource-icon">📱</div>
        <div>
          <strong>National Health Helpline: 104</strong>
          <p>Free medical advice, available in Hindi and English.</p>
        </div>
      </div>
      <div class="resource-item">
        <div class="resource-icon">🩺</div>
        <div>
          <strong>Hamidia Hospital, Bhopal</strong>
          <p>Free OPD for women. Gynecology dept open Mon–Sat, 9am–1pm.</p>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- ✅ JavaScript: updates map when a doctor card is clicked -->
<script>
  function selectDoctor(cardEl, lat, lng, name, area) {
    // Remove active class from all cards
    document.querySelectorAll('.doctor-card').forEach(c => c.classList.remove('active-doctor'));

    // Add active class to clicked card
    cardEl.classList.add('active-doctor');

    // Update map iframe src to point to this doctor's location
    const zoom = 0.008; // tighter zoom — shows the specific area
    const bbox = `${lng - zoom},${lat - zoom},${lng + zoom},${lat + zoom}`;
    const mapSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${lat},${lng}`;

    document.getElementById('map-frame').src = mapSrc;

    // Update map title and area label
    document.getElementById('map-doctor-name').textContent = name;
    document.getElementById('map-area-badge').textContent = area;

    // Update "Open full map" link
    document.getElementById('map-open-link').href =
      `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lng}#map=16/${lat}/${lng}`;

    // Scroll to map smoothly
    document.getElementById('map-card').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>

<!-- ✅ Styles for active card + map header -->
<style>
  .doctor-card {
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
    position: relative;
  }

  .doctor-card:hover {
    border-color: #f472b6;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(244, 114, 182, 0.15);
  }

  .doctor-card.active-doctor {
    border-color: #ec4899;
    background: linear-gradient(135deg, rgba(236, 72, 153, 0.06), rgba(168, 85, 247, 0.04));
    box-shadow: 0 8px 28px rgba(236, 72, 153, 0.2);
  }

  .selected-indicator {
    display: none;
    font-size: 11px;
    color: #ec4899;
    font-weight: 600;
    margin-top: 8px;
    letter-spacing: 0.3px;
  }

  .doctor-card.active-doctor .selected-indicator {
    display: block;
  }

  .map-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .map-header h3 {
    margin: 0;
    font-size: 16px;
  }

  .map-area-label {
    background: linear-gradient(135deg, #ec4899, #a855f7);
    color: white;
    font-size: 12px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.3px;
  }

  .map-link {
    display: inline-block;
    margin-top: 10px;
    font-size: 13px;
    color: #ec4899;
    text-decoration: none;
    font-weight: 500;
  }

  .map-link:hover {
    text-decoration: underline;
  }
</style>

<%- include('partials/footer') %>
