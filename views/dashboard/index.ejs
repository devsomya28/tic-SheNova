<!DOCTYPE html>
<html>
<head>
  <title>Herlytics</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'dashboard' }) %>

  <main class="main-content">

    <!-- Greeting -->
    <div style="margin-bottom:1.75rem;">
      <h1>
        Good <%= (new Date().getHours() < 12) ? 'morning' : (new Date().getHours() < 18 ? 'afternoon' : 'evening') %>,
        <%= user?.name ? user.name.split(' ')[0] : 'User' %> 🌸
      </h1>

      <p class="text-muted text-sm">
        <%= new Date().toLocaleDateString('en-IN', { weekday:'long', day:'numeric', month:'long', year:'numeric' }) %>
      </p>
    </div>

    <!-- Risk Score -->
    <div>
      <h2>PCOS Risk Score</h2>
      <p><%= user?.riskScore ?? 0 %></p>
      <span><%= user?.riskLevel || 'low' %> risk</span>
    </div>

    <!-- Cycle Stats -->
    <% if (cycleStats && cycleStats.phase) { %>
      <div>
        <h3><%= cycleStats.phase.name %> Phase</h3>
        <p>Day <%= cycleStats.dayOfCycle || 0 %></p>
      </div>
    <% } else { %>
      <p>No cycle data yet.</p>
    <% } %>

    <!-- Logs -->
    <div>
      <p>Total Logs: <%= cycleLogs?.length || 0 %></p>
    </div>

    <!-- Nutrition -->
    <div>
      <p>Calories Today: <%= todayNutrition?.totalCalories || 0 %></p>
      <p>Water: <%= todayNutrition?.waterGlasses || 0 %> glasses</p>
    </div>

    <!-- Risk Flags -->
    <div>
      <h3>Risk Flags</h3>

      <% if (user?.riskFlags && user.riskFlags.length > 0) { %>
        <ul>
          <% user.riskFlags.forEach(flag => { %>
            <li><%= flag %></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No risk flags</p>
      <% } %>
    </div>

  </main>
</div>

</body>
</html>