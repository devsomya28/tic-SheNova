<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Medical Report – <%= user.name %></title>
  <style>
    /* ── Screen styles ── */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background: #f4f4f8;
      color: #1e1e2e;
      padding: 30px;
    }

    .print-btn {
      display: block;
      margin: 0 auto 24px auto;
      padding: 12px 32px;
      background: #7c3aed;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      width: fit-content;
    }
    .print-btn:hover { background: #5b21b6; }

    .report-wrapper {
      max-width: 820px;
      margin: 0 auto;
      background: #fff;
      border-radius: 12px;
      padding: 48px 52px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }

    /* ── Header ── */
    .report-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 3px solid #7c3aed;
      padding-bottom: 20px;
      margin-bottom: 28px;
    }
    .report-header h1 {
      font-size: 24px;
      color: #7c3aed;
      font-weight: 700;
    }
    .report-header p { font-size: 13px; color: #666; margin-top: 4px; }
    .report-header .meta { text-align: right; font-size: 13px; color: #555; }
    .report-header .meta strong { color: #1e1e2e; }

    /* ── Section ── */
    section { margin-bottom: 32px; }
    section h2 {
      font-size: 15px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #7c3aed;
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 8px;
      margin-bottom: 16px;
    }

    /* ── Grid cards ── */
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 14px;
    }
    .card {
      background: #f9f5ff;
      border: 1px solid #ede9fe;
      border-radius: 10px;
      padding: 14px 16px;
    }
    .card .label { font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
    .card .value { font-size: 22px; font-weight: 700; color: #4c1d95; margin-top: 4px; }
    .card .unit  { font-size: 12px; color: #888; }

    /* ── Risk badge ── */
    .risk-box {
      display: flex;
      align-items: center;
      gap: 18px;
      background: #fdf4ff;
      border: 1px solid #e9d5ff;
      border-radius: 10px;
      padding: 18px 22px;
    }
    .risk-score {
      font-size: 44px;
      font-weight: 800;
      line-height: 1;
    }
    .risk-low    { color: #16a34a; }
    .risk-medium { color: #d97706; }
    .risk-high   { color: #dc2626; }

    .risk-details .level {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .risk-details p { font-size: 13px; color: #555; max-width: 400px; }

    /* ── Symptom bars ── */
    .symptom-row { margin-bottom: 12px; }
    .symptom-row .s-label {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      margin-bottom: 4px;
    }
    .bar-track {
      height: 10px;
      background: #ede9fe;
      border-radius: 99px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #7c3aed, #a78bfa);
      border-radius: 99px;
      transition: width 0.4s;
    }

    /* ── Cycle log table ── */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th {
      background: #f3f0ff;
      color: #4c1d95;
      font-weight: 600;
      text-align: left;
      padding: 10px 12px;
      border-bottom: 2px solid #ddd6fe;
    }
    td { padding: 9px 12px; border-bottom: 1px solid #f0f0f0; }
    tr:last-child td { border-bottom: none; }

    /* ── Population comparison ── */
    .pop-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 14px;
      padding: 8px 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .pop-row:last-child { border: none; }
    .pop-badge {
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 99px;
    }
    .pop-normal  { background: #dcfce7; color: #166534; }
    .pop-short   { background: #fef9c3; color: #854d0e; }
    .pop-long    { background: #fee2e2; color: #991b1b; }

    /* ── Footer ── */
    .report-footer {
      margin-top: 40px;
      border-top: 1px solid #e5e7eb;
      padding-top: 16px;
      font-size: 11px;
      color: #9ca3af;
      text-align: center;
    }

    /* ── Print overrides ── */
    @media print {
      body { background: #fff; padding: 0; }
      .print-btn { display: none; }
      .report-wrapper { box-shadow: none; border-radius: 0; padding: 32px 40px; }
      section { page-break-inside: avoid; }
    }
  </style>
</head>
<body>

  <button class="print-btn" onclick="window.print()">🖨️ Print / Save as PDF</button>

  <div class="report-wrapper">

    <!-- ── HEADER ── -->
    <div class="report-header">
      <div>
        <h1>Menstrual Health Report</h1>
        <p>Cycle Insights & PCOS Risk Assessment</p>
      </div>
      <div class="meta">
        <div><strong>Patient:</strong> <%= user.name %></div>
        <div><strong>Age:</strong> <%= user.age || 'N/A' %></div>
        <div><strong>Generated:</strong> <%= generatedOn %></div>
        <% if (user.email) { %>
        <div><strong>Email:</strong> <%= user.email %></div>
        <% } %>
      </div>
    </div>

    <!-- ── CYCLE STATS ── -->
    <section>
      <h2>Cycle Statistics</h2>
      <% if (stats) { %>
      <div class="card-grid">
        <div class="card">
          <div class="label">Avg. Cycle Length</div>
          <div class="value"><%= stats.avg %><span class="unit"> days</span></div>
        </div>
        <div class="card">
          <div class="label">Shortest Cycle</div>
          <div class="value"><%= stats.min %><span class="unit"> days</span></div>
        </div>
        <div class="card">
          <div class="label">Longest Cycle</div>
          <div class="value"><%= stats.max %><span class="unit"> days</span></div>
        </div>
        <div class="card">
          <div class="label">Cycles Logged</div>
          <div class="value"><%= logs.length %></div>
        </div>
        <% if (stats.stdDev !== undefined) { %>
        <div class="card">
          <div class="label">Irregularity (SD)</div>
          <div class="value"><%= stats.stdDev.toFixed(1) %><span class="unit"> days</span></div>
        </div>
        <% } %>
      </div>
      <% } else { %>
        <p style="color:#888; font-style:italic;">Not enough cycle data to compute statistics.</p>
      <% } %>
    </section>

    <!-- ── PCOS RISK ── -->
    <section>
      <h2>PCOS Risk Assessment</h2>
      <% if (risk) {
           const score = risk.score || risk;
           const level = score >= 70 ? 'High' : score >= 40 ? 'Moderate' : 'Low';
           const cls   = score >= 70 ? 'risk-high' : score >= 40 ? 'risk-medium' : 'risk-low';
           const desc  = score >= 70
             ? 'Elevated indicators suggest a detailed gynaecological evaluation is recommended.'
             : score >= 40
             ? 'Some risk factors present. Lifestyle monitoring and follow-up advised.'
             : 'Low risk indicators. Continue regular health monitoring.';
      %>
      <div class="risk-box">
        <div class="risk-score <%= cls %>"><%= score %>%</div>
        <div class="risk-details">
          <div class="level <%= cls %>"><%= level %> Risk</div>
          <p><%= desc %></p>
        </div>
      </div>
      <% } else { %>
        <p style="color:#888; font-style:italic;">Risk data unavailable.</p>
      <% } %>
    </section>

    <!-- ── POPULATION COMPARISON ── -->
    <% if (populationStats) { %>
    <section>
      <h2>Population Comparison</h2>
      <%
        const comparisons = [
          { label: 'Average Cycle Length', userVal: stats.avg + ' days', status: populationStats.avgStatus },
          { label: 'Cycle Regularity',     userVal: populationStats.regularityLabel, status: populationStats.regularityStatus },
        ];
        if (populationStats.percentile !== undefined) {
          comparisons.push({ label: 'Percentile (vs population)', userVal: populationStats.percentile + 'th', status: 'normal' });
        }
      %>
      <% comparisons.forEach(row => { %>
      <div class="pop-row">
        <span><%= row.label %></span>
        <span class="pop-badge pop-<%= row.status || 'normal' %>"><%= row.userVal %></span>
      </div>
      <% }); %>
    </section>
    <% } %>

    <!-- ── SYMPTOMS ── -->
    <% if (symptomFreqs) { %>
    <section>
      <h2>Reported Symptoms (Population Frequency)</h2>
      <%
        const symptoms = [
          { key: 'heavy_flow', label: 'Heavy Flow' },
          { key: 'acne',       label: 'Acne' },
          { key: 'back_pain',  label: 'Back Pain' },
          { key: 'clots',      label: 'Clots' },
        ];
      %>
      <% symptoms.forEach(s => { %>
        <% const pct = Math.round((symptomFreqs[s.key] || 0) * 100); %>
        <div class="symptom-row">
          <div class="s-label">
            <span><%= s.label %></span>
            <span><%= pct %>% of users report this</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width:<%= pct %>%"></div>
          </div>
        </div>
      <% }); %>
    </section>
    <% } %>

    <!-- ── CYCLE HISTORY TABLE ── -->
    <section>
      <h2>Cycle History (Last <%= Math.min(logs.length, 12) %> cycles)</h2>
      <% if (logs.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Period Start</th>
            <th>Cycle Length</th>
            <th>Flow</th>
            <th>Symptoms</th>
          </tr>
        </thead>
        <tbody>
          <% logs.slice(0, 12).forEach((log, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= new Date(log.periodStartDate).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></td>
            <td><%= log.cycleLength ? log.cycleLength + ' days' : '—' %></td>
            <td><%= log.flow || '—' %></td>
            <td><%= (log.symptoms && log.symptoms.length > 0) ? log.symptoms.join(', ') : 'None reported' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } else { %>
        <p style="color:#888; font-style:italic;">No cycle logs recorded yet.</p>
      <% } %>
    </section>

    <!-- ── FOOTER ── -->
    <div class="report-footer">
      <p>This report is auto-generated by the CycleTracker app and is intended as a supplementary tool for medical consultation.</p>
      <p>It does not constitute a medical diagnosis. Please consult a qualified gynaecologist for clinical advice.</p>
    </div>

  </div>
</body>
</html>